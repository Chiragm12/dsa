class Solution {
public:
    int singleNumber(vector<int>& nums) {
        unordered_map<int, int> freq; // 1. Create a hashmap to store frequencies
        for (int num : nums) {
            freq[num]++;              // 2. Count how many times each number appears
        }
        for (auto& p : freq) {
            if (p.second == 1)        // 3. Find and return the number with frequency 1
                return p.first;
        }
        return -1; // 4. If not found (edge case)
    }
};


//how to iterate hash map, instead of iterating through all numbers do this
class Solution {
public:
    int majorityElement(vector<int>& nums) {
       unordered_map<int,int> hash;
       int n=nums.size();
       for(auto num:nums) hash[num]++;
       for(auto[key,value]:hash){    // very very important
        if(value > (n/2)) return key;
       }
       return -1;
    }
};