class Solution {
public:
    vector<int> productExceptSelf(vector<int>& nums) {
        vector<int>res;
        for(int i=0;i<nums.size();i++){
            int j=0;
            int temp=1;
            while(j!=i){
                temp=nums[j]*temp;
                j++;
            }
            int k=i+1;
            while(k!=nums.size()){
                temp=nums[k]*temp;
                k++;
            }
            res.push_back(temp);
        }
        return res;
    }
};