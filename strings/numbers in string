class Solution {
public:
    string largestOddNumber(string num) {
        string maxSub;
        for (int i = 0; i < num.length(); i++) {
            string sub =
                num.substr(0, i + 1); // from begining till where u want
            char last_digit = sub.back();
            if ((last_digit - '0') % 2 != 0) { // if last digit is odd
                if (maxSub == "" || sub > maxSub) {
                    maxSub = sub; // keep updating
                }
            }
        }
        return maxSub;
    }
};