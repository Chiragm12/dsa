// matrix.size() gives number of rows (not columns).
// matrix[0].size() gives number of columns (assuming matrix is not empty)
// here we do this so that we can minimize time complexity, the 2-d matrix is sorted, so after finding which row the ele can be in,
// we do binary searh to that row to find the element
#include <iostream>
#include <vector>
using namespace std;

class Solution {
public:
    bool searchMatrix(vector<vector<int>>& matrix, int target) {
        int n = matrix.size();         // rows
        int m = matrix[0].size();      // columns
        
        for(int i = 0; i < n; i++) {
            // Only search in row if target could be present
            if (target >= matrix[i][0] && target <= matrix[i][m - 1]) {
                int low = 0, high = m - 1;
                while (low <= high) {
                    int mid = low + (high - low) / 2;
                    if (matrix[i][mid] == target) {
                        return true;
                    } else if (matrix[i][mid] > target) {
                        high = mid - 1;
                    } else {
                        low = mid + 1;
                    }
                }
            }
        }
        
        return false;
    }
};
