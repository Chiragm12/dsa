and for checking we use a ds to push the elements so-> if(level==ds.size())ds.add(node->data)


int the ds, the size is initally 0, and the level is also 0 hence the data gets added. 

class Solution {
public:
    vector<int> rightSideView(TreeNode* root) {
        vector<int> res;
        rec(root,0,res);
        return res;
    }
    void rec(TreeNode* root,int level,vector<int> &res){
        if(root==NULL) return;
        if(res.size()==level) res.push_back(root->val);
        rec(root->right,level+1,res);
        rec(root->left,level+1,res);
        
    }
};

