// we need to check if the tree is symm, so the root node is constant, then we'll have 2 trees the right and left one, 
// symm basically means that the left side should be a mirror image of the right side, so we do that by using inorder or preorder
// we use inorder, so left hand mai we do root left right, and since right side is mirror we do right side mai root right left aste


class Solution {
public:
    bool isSymmetric(TreeNode* root) {
        return root==nullptr ||issymm(root->left,root->right);
    }
    bool issymm(TreeNode*left,TreeNode*right){
        if(left==nullptr||right==nullptr) return left==right;
        if(left->val!=right->val) return false;
        return issymm(left->left,right->right)&&issymm(left->right,right->left);
    }
};