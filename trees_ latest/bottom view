//same logic as top view, so in bottom view, if we see a element that
//already existst in the map, replace it with the data which u encounter asthe


class Solution {
  public:
    vector<int> bottomView(Node *root) {
        vector<int> ans;
        if (root == nullptr) return ans;  // ✅ null check first

        // Queue to store nodes with horizontal distance (line)
        queue<pair<Node*, int>> q;
        q.push({root, 0});

        // Map to store line → last node value (bottom-most)
        map<int, int> mpp;

        while (!q.empty()) {
            auto it = q.front();
            q.pop();

            Node* node = it.first;
            int line = it.second;

            // For bottom view: overwrite the previous value for each line
            mpp[line] = node->data;

            if (node->left != nullptr)
                q.push({node->left, line - 1});

            if (node->right != nullptr)
                q.push({node->right, line + 1});
        }

        // Extract bottom view in order from leftmost to rightmost line
        for (auto ap : mpp) {
            ans.push_back(ap.second);
        }

        return ans;
    }
};

